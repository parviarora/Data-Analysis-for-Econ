        "### Q4: The Gender Audit (15 pts)\n",
        "\n",
        "The Ministry’s first question: **Is there a gender pay gap in HireVision’s data?**\n",
        "\n",
        "**Part A (8 pts):** Write a function that computes the gender gap two ways:\n",
        "1. **Raw gap:** Welch’s t-test on `log_salary` between Male and Female.\n",
        "2. **Controlled gap:** OLS with gender, controlling for GPA, internships, field, and work experience.\n",
        "\n",
        "**Part B (7 pts):** The Ministry also asks whether college type and city tier are independent. Write a function that runs a chi-square test and computes Cramér’s V."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "tnUpPGyAo-uR"
      },
      "outputs": [],
      "source": [
        "import numpy as np\n",
        "import statsmodels.formula.api as smf\n",
        "from scipy import stats\n",
        "import pandas as pd\n",
        "from scipy.stats import chi2_contingency\n",
        "\n",
        "def audit_gender_gap(df):\n",
        "    \"\"\"\n",
        "    Compute gender salary gap two ways: raw (t-test) and controlled (OLS).\n",
        "\n",
        "    Args:\n",
        "        df: DataFrame with columns 'log_salary', 'gender', 'gpa', 'internships',\n",
        "            'field', 'work_experience_months'\n",
        "\n",
        "    Returns:\n",
        "        dict with keys:\n",
        "            raw_t_stat:       float (t-statistic from Welch's t-test, Male - Female)\n",
        "            raw_p_value:      float\n",
        "            raw_pct_gap:      float ((exp(mean_male - mean_female) - 1) * 100)\n",
        "            controlled_pct_gap: float ((exp(gender_coeff) - 1) * 100)\n",
        "            controlled_p_value: float\n",
        "            gap_shrinks:      bool (abs(controlled_pct_gap) < abs(raw_pct_gap))\n",
        "    \"\"\"\n",
        "\n",
        "    # --- Raw gap (Welch t-test) ---\n",
        "    male = df[df['gender'] == 'Male']['log_salary']\n",
        "    female = df[df['gender'] == 'Female']['log_salary']\n",
        "\n",
        "    t_stat, p_val = stats.ttest_ind(male, female, equal_var=False)\n",
        "\n",
        "    mean_male = male.mean()\n",
        "    mean_female = female.mean()\n",
        "\n",
        "    raw_pct_gap = (np.exp(mean_male - mean_female) - 1) * 100\n",
        "\n",
        "    # --- Controlled gap (OLS) ---\n",
        "    model = smf.ols(\n",
        "        'log_salary ~ C(gender) + gpa + internships + C(field) + work_experience_months',\n",
        "        data=df\n",
        "    ).fit(cov_type='HC3')\n",
        "\n",
        "    gender_coeff = model.params['C(gender)[T.Male]']\n",
        "    controlled_pct_gap = (np.exp(gender_coeff) - 1) * 100\n",
        "    controlled_p_val = model.pvalues['C(gender)[T.Male]']\n",
        "\n",
        "    # --- Gap shrink check ---\n",
        "    gap_shrinks = abs(controlled_pct_gap) < abs(raw_pct_gap)\n",
        "\n",
        "    return {\n",
        "        'raw_t_stat': t_stat,\n",
        "        'raw_p_value': p_val,\n",
        "        'raw_pct_gap': raw_pct_gap,\n",
        "        'controlled_pct_gap': controlled_pct_gap,\n",
        "        'controlled_p_value': controlled_p_val,\n",
        "        'gap_shrinks': gap_shrinks\n",
        "    }\n",
        "\n",
        "\n",
        "def test_college_city(df):\n",
        "    \"\"\"\n",
        "    Chi-square test of independence between college_type and city_tier.\n",
        "\n",
        "    Returns:\n",
        "        dict with keys:\n",
        "            chi2:       float\n",
        "            p_value:    float\n",
        "            dof:        int\n",
        "            significant: bool (at alpha=0.05)\n",
        "            cramers_v:  float\n",
        "            strength:   str ('weak' if V < 0.1, 'moderate' if 0.1 <= V <= 0.3,\n",
        "                             'strong' if V > 0.3)\n",
        "    \"\"\"\n",
        "\n",
        "    # Contingency table\n",
        "    table = pd.crosstab(df['college_type'], df['city_tier'])\n",
        "\n",
        "    chi2, p, dof, expected = chi2_contingency(table)\n",
        "\n",
        "    # Cramér's V\n",
        "    n = table.sum().sum()\n",
        "    min_dim = min(table.shape) - 1\n",
        "    cramers_v = np.sqrt(chi2 / (n * min_dim))\n",
        "\n",
        "    # Significance\n",
        "    significant = p < 0.05\n",
        "\n",
        "    # Strength interpretation\n",
        "    if cramers_v < 0.1:\n",
        "        strength = 'weak'\n",
        "    elif cramers_v <= 0.3:\n",
        "        strength = 'moderate'\n",
        "    else:\n",
        "        strength = 'strong'\n",
        "\n",
        "    return {\n",
        "        'chi2': chi2,\n",
        "        'p_value': p,\n",
        "        'dof': dof,\n",
        "        'significant': significant,\n",
        "        'cramers_v': cramers_v,\n",
        "        'strength': strength\n",
        "    }\n"
      ]
