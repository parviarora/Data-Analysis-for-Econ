      "source": [
        "def safe_merge(left, right, on, how='inner'):\n",
        "    \"\"\"Robust merge that handles three edge cases:\n",
        "\n",
        "    1. Empty/null merge keys: drop rows where the key is empty string or NaN\n",
        "       (in both DataFrames) before merging\n",
        "    2. Duplicate keys: deduplicate both DataFrames on the key column (keep first)\n",
        "       before merging\n",
        "    3. Type mismatch: if key column dtype differs between left and right,\n",
        "       coerce both to string before merging\n",
        "\n",
        "    Args:\n",
        "        left: Left DataFrame\n",
        "        right: Right DataFrame\n",
        "        on: Column name to merge on (must exist in both)\n",
        "        how: Merge type (default 'inner')\n",
        "\n",
        "    Returns:\n",
        "        Merged DataFrame with edge cases handled\n",
        "    \"\"\"\n",
        "   # Make copies to avoid modifying original data\n",
        "    left = left.copy()\n",
        "    right = right.copy()\n",
        "\n",
        "    # 1. Drop empty string and NaN keys\n",
        "    left = left[left[on].notna() & (left[on] != \"\")]\n",
        "    right = right[right[on].notna() & (right[on] != \"\")]\n",
        "\n",
        "    # 2. Handle type mismatch (coerce both to string if different)\n",
        "    if left[on].dtype != right[on].dtype:\n",
        "        left[on] = left[on].astype(str)\n",
        "        right[on] = right[on].astype(str)\n",
        "\n",
        "    # 3. Deduplicate both sides (keep first)\n",
        "    left = left.drop_duplicates(subset=[on])\n",
        "    right = right.drop_duplicates(subset=[on])\n",
        "\n",
        "    # Merge\n",
        "    merged = left.merge(right, on=on, how=how)\n",
        "\n",
        "    return merged"
      ]
    },
