      "metadata": {
        "id": "Tyh_3wH-epB3"
      },
      "source": [
        "Now write a function that:\n",
        "1. Filters `whr_clean` to the latest year available\n",
        "2. Merges with `countries_df` on country name (after applying `NAME_MAP` to `countries_df['name']`)\n",
        "3. Computes happiness by region\n",
        "4. Finds which of the 6 WHR factors has the strongest correlation with happiness\n",
        "5. Finds India's rank\n",
        "\n",
        "Return a dict with the keys shown in the docstring below."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "q4y9Ti16epB3"
      },
      "outputs": [],
      "source": [
        "def build_happiness_profile(whr_df, countries_df, fx_df):\n",
        "    # 1. Filter latest year\n",
        "    latest_year = whr_df['year'].max()\n",
        "    df = whr_df[whr_df['year'] == latest_year].copy()\n",
        "\n",
        "    # 2. Standardize country names in countries_df\n",
        "    countries_df = countries_df.copy()\n",
        "    countries_df['country'] = countries_df['name'].map(NAME_MAP).fillna(countries_df['name'])\n",
        "\n",
        "    # Merge\n",
        "    merged = df.merge(countries_df, on='country', how='inner')\n",
        "\n",
        "    # 3. Happiness by region\n",
        "    region_mean = merged.groupby('region')['happiness'].mean()\n",
        "    happiest_region = region_mean.idxmax()\n",
        "    saddest_region = region_mean.idxmin()\n",
        "\n",
        "    # 4. Strongest factor (absolute correlation)\n",
        "    factors = ['log_gdp', 'social_support', 'health', 'freedom', 'generosity', 'corruption']\n",
        "    corr = merged[factors + ['happiness']].corr()['happiness'].drop('happiness').abs()\n",
        "    strongest_factor = corr.idxmax()\n",
        "\n",
        "    # 5. India rank\n",
        "    merged = merged.sort_values(by='happiness', ascending=False).reset_index(drop=True)\n",
        "    merged['rank'] = merged.index + 1\n",
        "    india_rank = merged.loc[merged['country'] == 'India', 'rank'].iloc[0]\n",
        "\n",
        "    return {\n",
        "        'n_countries': merged['country'].nunique(),\n",
        "        'happiest_region': happiest_region,\n",
        "        'saddest_region': saddest_region,\n",
        "        'strongest_factor': strongest_factor,\n",
        "        'india_rank': int(india_rank)\n",
        "    }"
      ]
    },
