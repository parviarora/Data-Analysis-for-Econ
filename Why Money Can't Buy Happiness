        "      # 1. Drop NaN and empty keys\n",
        "    left_clean = left[left[left_key].notna() & (left[left_key] != \"\")]\n",
        "    right_clean = right[right[right_key].notna() & (right[right_key] != \"\")]\n",
        "\n",
        "    # 2. Deduplicate right side\n",
        "    right_clean = right_clean.drop_duplicates(subset=[right_key])\n",
        "\n",
        "    # 3. Merge\n",
        "    merged = left_clean.merge(\n",
        "        right_clean,\n",
        "        left_on=left_key,\n",
        "        right_on=right_key,\n",
        "        how='inner'\n",
        "    )\n",
        "\n",
        "    return merged"
