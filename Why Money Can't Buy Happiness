        "def fix_api_fetch(base_url, start_date, end_date, currencies):\n",
        "    \"\"\"Fetch exchange rates using a single range query with error handling.\n",
        "\n",
        "    Args:\n",
        "        base_url: API base URL (e.g., 'https://api.frankfurter.app')\n",
        "        start_date: Start date string (e.g., '2024-01-01')\n",
        "        end_date: End date string (e.g., '2024-01-31')\n",
        "        currencies: List of currency codes (e.g., ['INR', 'EUR'])\n",
        "\n",
        "    Returns:\n",
        "        DataFrame with 'date' column and one column per currency,\n",
        "        or empty DataFrame on failure\n",
        "    \"\"\"\n",
        "    # YOUR CODE HERE\n",
        "    import urllib.request, json\n",
        "    import pandas as pd\n",
        "\n",
        "    try:\n",
        "        # Single range query\n",
        "        url = f\"{base_url}/{start_date}..{end_date}?from=USD&to={','.join(currencies)}\"\n",
        "        resp = urllib.request.urlopen(url)\n",
        "        data = json.loads(resp.read())\n",
        "\n",
        "        rates = data.get('rates', {})\n",
        "\n",
        "        # Convert to DataFrame\n",
        "        df = pd.DataFrame.from_dict(rates, orient='index')\n",
        "        df.index.name = 'date'\n",
        "        df = df.reset_index()\n",
        "\n",
        "        # Ensure correct column order\n",
        "        cols = ['date'] + currencies\n",
        "        df = df[cols]\n",
        "\n",
        "        return df\n",
        "\n",
        "    except Exception:\n",
        "        # Return empty DataFrame on failure\n",
        "        return pd.DataFrame(columns=['date'] + currencies)\n",
        "\n",
        "def fix_robust_merge(left, right, left_key, right_key):\n",
        "    \"\"\"Merge two DataFrames with key validation.\n",
        "\n",
        "    1. Drop rows where key is empty string or NaN (both sides)\n",
        "    2. Deduplicate right DataFrame on right_key (keep first)\n",
        "    3. Inner merge\n",
        "\n",
        "    Returns:\n",
        "        Merged DataFrame\n",
        "    \"\"\"\n",
